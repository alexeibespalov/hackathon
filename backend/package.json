{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "db:schema:local": "wrangler d1 execute airport-booking --local --file=src/db/schema.sql",
    "db:schema:remote": "CI=true wrangler d1 execute airport-booking --remote --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute airport-booking --local --file=src/db/seed.sql",
    "db:seed:remote": "CI=true wrangler d1 execute airport-booking --remote --file=src/db/seed.sql",
    "deploy": "wrangler deploy",
    "deploy:cloudflare": "npm run build && npm run cf-typegen && npm run db:schema:remote && npm run db:seed:remote && npm run deploy",
    "dev": "npm run build && wrangler dev",
    "dev:client": "vite",
    "dev:worker": "wrangler dev",
    "start": "npm run dev",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.2",
    "vite": "^7.3.3",
    "vitest": "~3.2.0",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.23",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  }
}
